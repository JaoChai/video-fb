<!doctype html>
<html lang="th" data-resolution="portrait">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1080, height=1920" />
    <script src="assets/gsap.min.js"></script>
    <style>
      /* ── Local Thai font (no Google Fonts: external requests fail in sandboxed render) ── */
      @font-face {
        font-family: "Sarabun";
        src: url("assets/fonts/Sarabun-Regular.ttf") format("truetype");
        font-weight: 400;
        font-display: block;
      }
      @font-face {
        font-family: "Sarabun";
        src: url("assets/fonts/Sarabun-SemiBold.ttf") format("truetype");
        font-weight: 600;
        font-display: block;
      }
      @font-face {
        font-family: "Sarabun";
        src: url("assets/fonts/Sarabun-Bold.ttf") format("truetype");
        font-weight: 700;
        font-display: block;
      }
      @font-face {
        font-family: "Sarabun";
        src: url("assets/fonts/Sarabun-ExtraBold.ttf") format("truetype");
        font-weight: 800;
        font-display: block;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        width: 1080px;
        height: 1920px;
        overflow: hidden;
        background: #0a1428;
      }

      /* ─────────────────────────  THEME  ───────────────────────── */
      #root {
        --navy-deep: #0a1428;
        --navy: #0f1d35;
        --navy-hi: #16284a;
        --orange: {{.AccentColor}};
        --orange-soft: #ff8a52;
        --orange-bright: #ff9457;
        --ink: #f4f7fb;
        --muted: #aebdd4;
        --green: {{.SecondaryAccent}};
        --red: #ff5a52;

        width: 1080px;
        height: 1920px;
        position: relative;
        overflow: hidden;
        font-family: "Sarabun", sans-serif;
        color: var(--ink);
        background: var(--navy-deep);
      }

      /* ── Background ── */
      .bg-img-wrap {
        position: absolute;
        inset: 0;
        overflow: hidden;
      }
      .bg-img-wrap img {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 1080px;
        height: 1920px;
        object-fit: cover;
        transform: translate(-50%, -50%);
        transform-origin: center center;
        will-change: transform;
      }
      .bg-base {
        position: absolute;
        inset: 0;
        background: radial-gradient(
          120% 80% at 50% 0%,
          #16284a 0%,
          #0f1d35 45%,
          #0a1428 100%
        );
      }
      .bg-glow {
        position: absolute;
        inset: -10%;
        background:
          radial-gradient(
            40% 30% at 22% 18%,
            rgba(255, 107, 43, 0.16) 0%,
            rgba(255, 107, 43, 0) 60%
          ),
          radial-gradient(
            46% 34% at 82% 72%,
            rgba(47, 132, 209, 0.18) 0%,
            rgba(47, 132, 209, 0) 62%
          );
      }
      .bg-dots {
        position: absolute;
        inset: -120px;
        background-image: radial-gradient(
          rgba(255, 255, 255, 0.07) 2px,
          transparent 2px
        );
        background-size: 46px 46px;
        will-change: transform;
      }
      .bg-circuit {
        position: absolute;
        inset: 0;
        opacity: 0.5;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
        background-size: 138px 138px;
        will-change: transform;
      }
      .bg-vignette {
        position: absolute;
        inset: 0;
        background: radial-gradient(
          120% 100% at 50% 50%,
          rgba(10, 20, 40, 0) 50%,
          rgba(8, 16, 32, 0.55) 100%
        );
      }
      .bg-scrim {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          180deg,
          rgba(10, 20, 40, 0.7) 0%,
          rgba(10, 20, 40, 0.28) 26%,
          rgba(10, 20, 40, 0.32) 54%,
          rgba(10, 20, 40, 0.78) 100%
        );
      }

      /* ── Progress bar ── */
      .progress-track {
        position: absolute;
        top: 0;
        left: 0;
        width: 1080px;
        height: 8px;
        background: rgba(255, 255, 255, 0.08);
      }
      .progress-fill {
        position: absolute;
        top: 0;
        left: 0;
        width: 0px;
        height: 8px;
        background: linear-gradient(90deg, var(--orange), var(--orange-soft));
        box-shadow: 0 0 18px rgba(255, 107, 43, 0.6);
      }

      /* ── Badges ── */
      .badge-row {
        position: absolute;
        top: 96px;
        left: 72px;
        display: flex;
        align-items: center;
        gap: 18px;
      }
      .badge-brand {
        font-weight: 800;
        font-size: 30px;
        letter-spacing: 0.14em;
        color: #fff;
        background: var(--orange);
        padding: 14px 26px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(255, 107, 43, 0.35);
      }
      .badge-cat {
        font-weight: 700;
        font-size: 24px;
        letter-spacing: 0.22em;
        color: var(--orange);
        border: 2px solid rgba(255, 107, 43, 0.55);
        padding: 12px 22px;
        border-radius: 12px;
        background: rgba(255, 107, 43, 0.08);
      }

      /* ── Intro block ── */
      .intro {
        position: absolute;
        top: 380px;
        left: 72px;
        right: 72px;
      }
      .intro-eyebrow {
        font-weight: 700;
        font-size: 28px;
        letter-spacing: 0.04em;
        color: var(--orange);
        margin-bottom: 26px;
      }
      .intro-title {
        font-weight: 800;
        font-size: 84px;
        line-height: 1.12;
        letter-spacing: -0.01em;
        color: #fff;
        text-shadow: 0 6px 30px rgba(0, 0, 0, 0.55);
        max-width: 880px;
      }
      .intro-title .hl {
        color: var(--orange-bright);
        text-shadow: 0 4px 22px rgba(0, 0, 0, 0.85);
      }
      .intro-asker {
        display: inline-block;
        margin-top: 34px;
        font-weight: 600;
        font-size: 34px;
        color: var(--muted);
        background: rgba(8, 16, 32, 0.72);
        padding: 14px 26px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.08);
      }
      .intro-asker b {
        color: #ffffff;
        font-weight: 700;
      }

      /* ── Point cards (upper-middle, above captions) ── */
      .card {
        position: absolute;
        left: 72px;
        right: 72px;
        top: 560px;
        padding: 48px 52px;
        border-radius: 28px;
        background: rgba(15, 29, 53, 0.9);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.45);
        opacity: 0;
      }
      .card .kicker {
        display: inline-block;
        font-weight: 700;
        font-size: 24px;
        letter-spacing: 0.16em;
        color: var(--orange);
        margin-bottom: 22px;
      }
      .card .ctext {
        font-weight: 800;
        font-size: 58px;
        line-height: 1.24;
        color: #fff;
        max-width: 900px;
      }
      .card.step {
        display: flex;
        align-items: flex-start;
        gap: 36px;
      }
      .step-num {
        flex: 0 0 auto;
        width: 104px;
        height: 104px;
        border-radius: 24px;
        background: linear-gradient(135deg, var(--orange), var(--orange-soft));
        color: #fff;
        font-weight: 800;
        font-size: 58px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 14px 34px rgba(255, 107, 43, 0.4);
      }
      .step-body .step-label {
        font-weight: 700;
        font-size: 26px;
        letter-spacing: 0.14em;
        color: var(--orange);
        margin-bottom: 16px;
      }
      .step-body .step-text {
        font-weight: 700;
        font-size: 54px;
        line-height: 1.26;
        color: #fff;
        max-width: 720px;
      }
      .card.cause {
        border-color: rgba(255, 90, 82, 0.5);
        background: rgba(48, 18, 22, 0.88);
      }
      .card.cause .kicker {
        color: var(--red);
      }
      .card.win {
        border-color: rgba(47, 209, 122, 0.5);
        background: rgba(13, 44, 32, 0.9);
      }
      .card.win .kicker {
        color: var(--green);
      }

      /* ── Karaoke captions (lower third) ── */
      .cap-stage {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 480px;
        display: flex;
        justify-content: center;
        overflow: visible; /* required: never clip scaled/glow text */
        pointer-events: none;
      }
      .cap-phrase {
        position: absolute;
        bottom: 0;
        width: 920px;
        text-align: center;
        font-family: "Sarabun", sans-serif;
        font-weight: 700;
        line-height: 1.34;
        color: #ffffff;
        background: rgba(10, 20, 40, 0.82);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        padding: 30px 44px;
        opacity: 0;
        overflow: visible;
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.5);
      }
      .cap-phrase.active {
        border-color: rgba(255, 107, 43, 0.55);
      }

      /* ── Outro ── */
      .outro {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: linear-gradient(160deg, #0a1730 0%, #060d1c 100%);
      }
      .outro-brand {
        font-weight: 800;
        font-size: 96px;
        letter-spacing: 0.08em;
        color: #fff;
      }
      .outro-brand span {
        color: var(--orange-bright);
      }
      .outro-tag {
        margin-top: 26px;
        font-weight: 600;
        font-size: 40px;
        color: var(--muted);
        letter-spacing: 0.02em;
      }
      .outro-rule {
        margin-top: 40px;
        width: 0px;
        height: 5px;
        border-radius: 4px;
        background: var(--orange);
      }
    </style>
  </head>
  <body>
    <div
      id="root"
      data-composition-id="main"
      data-start="0"
      data-duration="{{.DurationSeconds}}"
      data-width="1080"
      data-height="1920"
    >
      <!-- ── Background — track 0 ── -->
      <div
        id="bg"
        class="clip"
        data-start="0"
        data-duration="{{.DurationSeconds}}"
        data-track-index="0"
        data-layout-allow-overflow
      >
        {{if eq .BackgroundMode "image"}}
        <div class="bg-img-wrap">
          <img src="{{.BackgroundImage}}" alt="" data-layout-allow-overflow />
        </div>
        <div class="bg-scrim"></div>
        {{else}}
        <div class="bg-base"></div>
        <div class="bg-glow"></div>
        <div class="bg-circuit" id="bgCircuit" data-layout-allow-overflow></div>
        <div class="bg-dots" id="bgDots" data-layout-allow-overflow></div>
        <div class="bg-vignette"></div>
        {{end}}
      </div>

      <!-- ── Progress bar — track 7 ── -->
      <div
        id="progress"
        class="clip progress-track"
        data-start="0"
        data-duration="{{.DurationSeconds}}"
        data-track-index="7"
      >
        <div class="progress-fill" id="progressFill"></div>
      </div>

      <!-- ── Badges — track 2 ── -->
      <div
        id="badges"
        class="clip badge-row"
        data-start="0.4"
        data-duration="12.8"
        data-track-index="2"
      >
        <div class="badge-brand">{{.BrandName}}</div>
        <div class="badge-cat">{{.CategoryLabel}}</div>
      </div>

      <!-- ── Intro title block — track 3 ── -->
      <div
        id="intro"
        class="clip intro"
        data-start="0.6"
        data-duration="12.6"
        data-track-index="3"
      >
        <div class="intro-eyebrow" id="introEyebrow">{{.Kicker}}</div>
        <div class="intro-title" id="introTitle">{{.TitleHTML}}</div>
        <div class="intro-asker" id="introAsker">
          คำถามจาก <b>{{.QuestionerName}}</b>
        </div>
      </div>

      <!-- ── Point cards injected by script — track 5/6 ── -->
      <div id="cardLayer"></div>

      <!-- ── Karaoke caption stage (phrases injected by script) — track 9 ── -->
      <div
        id="capStage"
        class="clip cap-stage"
        data-start="0"
        data-duration="{{.DurationSeconds}}"
        data-track-index="9"
        data-layout-allow-overflow
      ></div>

      <!-- ── Outro — track 8 ── -->
      <div
        id="outro"
        class="clip outro"
        data-start="{{.OutroStart}}"
        data-duration="{{.OutroDuration}}"
        data-track-index="8"
      >
        <div class="outro-brand">{{.OutroBrandHTML}}</div>
        <div class="outro-tag">ที่ปรึกษา Facebook Ads</div>
        <div class="outro-rule" id="outroRule"></div>
      </div>

      <!-- ── Voice-over audio — track 10 (no class="clip") ── -->
      <audio
        id="vo"
        data-start="0"
        data-duration="{{.DurationSeconds}}"
        data-track-index="10"
        src="{{.VoiceSrc}}"
        data-volume="1"
      ></audio>
    </div>

    <script>
      window.__timelines = window.__timelines || {};
      const tl = gsap.timeline({ paused: true });

      // ── Data injected by Go (template.JS — raw JSON, not escaped) ──
      const CARDS = {{.CardsJSON}};
      const SEGMENTS = {{.SegmentsJSON}};
      const TOTAL = {{.DurationSeconds}};
      const BG_MODE = "{{.BackgroundMode}}";

      // Entrance duration from AnimationSpeed (fast/normal/slow)
      const SPEED = "{{.AnimationSpeed}}";
      const ENTER = SPEED === "fast" ? 0.4 : SPEED === "slow" ? 0.8 : 0.6;
      const EXIT = ENTER * 0.8;

      /* ──────────────  BACKGROUND (whole clip)  ────────────── */
      if (BG_MODE === "image") {
        // Ken Burns slow zoom on the background image
        tl.fromTo("#bg img", { scale: 1.0 }, { scale: 1.12, duration: TOTAL, ease: "none" }, 0);
      } else {
        // Subtle drift + slow zoom on the CSS patterns
        tl.fromTo("#bgDots", { x: 0, y: 0 }, { x: 46, y: 46, duration: TOTAL, ease: "none" }, 0);
        tl.fromTo("#bgCircuit", { scale: 1.0 }, { scale: 1.06, duration: TOTAL, ease: "none" }, 0);
      }

      // Progress bar fills across full width over the whole clip
      tl.fromTo("#progressFill", { width: 0 }, { width: 1080, duration: TOTAL, ease: "none" }, 0);

      /* ──────────────────────  INTRO  ────────────────────── */
      tl.fromTo("#badges", { opacity: 0, x: -60 }, { opacity: 1, x: 0, duration: 0.8, ease: "power3.out" }, 0.4);
      tl.fromTo("#introEyebrow", { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.7, ease: "power2.out" }, 0.7);
      tl.fromTo("#introTitle", { opacity: 0, y: 60 }, { opacity: 1, y: 0, duration: 0.9, ease: "power3.out" }, 0.95);
      tl.fromTo("#introAsker", { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.7, ease: "power2.out" }, 1.5);
      tl.to("#badges", { opacity: 0, y: -24, duration: 0.6, ease: "power2.in" }, 12.6);
      tl.to("#intro", { opacity: 0, y: -40, duration: 0.7, ease: "power2.in" }, 12.5);

      /* ─────────────  POINT CARDS (data-driven)  ───────────── */
      const cardLayer = document.getElementById("cardLayer");

      function buildCard(card, idx) {
        const el = document.createElement("div");
        el.id = card.id || ("card" + idx);
        el.className = "clip card " + (card.type || "step");
        el.setAttribute("data-start", card.start);
        el.setAttribute("data-duration", Math.max(0.1, card.end - card.start).toFixed(3));
        // Alternate track 5/6 so adjacent cards never share a track (no overlap rule)
        el.setAttribute("data-track-index", idx % 2 === 0 ? "5" : "6");

        if (card.type === "step") {
          const num = document.createElement("div");
          num.className = "step-num";
          num.textContent = String(card.step != null ? card.step : idx + 1);
          const body = document.createElement("div");
          body.className = "step-body";
          if (card.kicker) {
            const lab = document.createElement("div");
            lab.className = "step-label";
            lab.textContent = card.kicker;
            body.appendChild(lab);
          }
          const txt = document.createElement("div");
          txt.className = "step-text";
          txt.textContent = card.body || "";
          body.appendChild(txt);
          el.appendChild(num);
          el.appendChild(body);
        } else {
          if (card.kicker) {
            const k = document.createElement("div");
            k.className = "kicker";
            k.textContent = card.kicker;
            el.appendChild(k);
          }
          const c = document.createElement("div");
          c.className = "ctext";
          c.textContent = card.body || "";
          el.appendChild(c);
        }
        cardLayer.appendChild(el);
        return el;
      }

      CARDS.forEach(function (card, idx) {
        const el = buildCard(card, idx);
        const sel = "#" + el.id;
        const fromRight = idx % 2 === 1; // alternate entrance direction
        const inAt = card.start;
        const outAt = card.end;
        const exitAt = Math.max(inAt + ENTER + 0.1, outAt - EXIT);

        if (fromRight) {
          tl.fromTo(el, { opacity: 0, x: 80 }, { opacity: 1, x: 0, duration: ENTER, ease: "power3.out" }, inAt);
          tl.to(el, { opacity: 0, x: -40, duration: EXIT, ease: "power2.in" }, exitAt);
        } else {
          tl.fromTo(el, { opacity: 0, y: 70, scale: 0.96 }, { opacity: 1, y: 0, scale: 1, duration: ENTER + 0.1, ease: "back.out(1.3)" }, inAt);
          tl.to(el, { opacity: 0, y: -36, duration: EXIT, ease: "power2.in" }, exitAt);
        }
        // Hard kill so non-linear seeking never leaves a stale card on screen
        tl.set(el, { opacity: 0 }, outAt);
      });

      /* ─────────────  DYNAMIC KARAOKE CAPTIONS  ───────────── */
      const capStage = document.getElementById("capStage");
      const hasFit =
        typeof window.__hyperframes !== "undefined" &&
        typeof window.__hyperframes.fitTextFontSize === "function";

      SEGMENTS.forEach(function (seg, i) {
        const el = document.createElement("div");
        el.className = "cap-phrase";
        el.textContent = seg.text;
        capStage.appendChild(el);

        if (hasFit) {
          const fit = window.__hyperframes.fitTextFontSize(seg.text, {
            fontFamily: "Sarabun",
            fontWeight: 700,
            maxWidth: 832, // 920 phrase width minus 2*44 padding
            baseFontSize: 46,
            minFontSize: 30,
          });
          el.style.fontSize = fit.fontSize + "px";
        } else {
          const len = seg.text.length;
          const size = len > 70 ? 32 : len > 45 ? 38 : len > 28 ? 44 : 50;
          el.style.fontSize = size + "px";
        }

        const inAt = seg.start;
        const outAt = i < SEGMENTS.length - 1 ? SEGMENTS[i + 1].start : seg.end;

        tl.fromTo(
          el,
          { opacity: 0, scale: 0.92, y: 24 },
          { opacity: 1, scale: 1.0, y: 0, duration: 0.32, ease: "power2.out" },
          inAt
        );
        tl.call(function () { el.classList.add("active"); }, null, inAt);
        tl.to(el, { scale: 1.05, duration: 0.22, ease: "power1.out" }, inAt + 0.04);
        tl.to(el, { scale: 1.0, duration: 0.5, ease: "power2.out" }, inAt + 0.3);
        tl.to(el, { opacity: 0, y: -18, duration: 0.26, ease: "power2.in" }, Math.max(inAt + 0.4, outAt - 0.22));
        tl.call(function () { el.classList.remove("active"); }, null, outAt);
        tl.set(el, { opacity: 0 }, outAt);
      });

      /* ─────────────────────  OUTRO  ───────────────────── */
      const outroStart = {{.OutroStart}};
      tl.fromTo("#outro", { opacity: 0 }, { opacity: 1, duration: 0.8, ease: "power2.out" }, outroStart);
      tl.fromTo(".outro-brand", { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" }, outroStart + 0.2);
      tl.fromTo(".outro-tag", { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.7, ease: "power2.out" }, outroStart + 0.6);
      tl.fromTo("#outroRule", { width: 0 }, { width: 220, duration: 0.9, ease: "power2.out" }, outroStart + 1.0);

      // Lock the composition to exactly the clip duration
      tl.set({}, {}, TOTAL);

      window.__timelines["main"] = tl;
    </script>
  </body>
</html>
