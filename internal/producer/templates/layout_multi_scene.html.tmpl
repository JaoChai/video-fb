{{define "layout_multi_scene.html.tmpl"}}<!doctype html>
<html lang="th" data-resolution="{{if eq .Width 1080}}portrait{{else}}landscape{{end}}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width={{.Width}}, height={{.Height}}" />
    <script src="assets/gsap.min.js"></script>
    <style>
      @font-face{font-family:"Sarabun";src:url("assets/fonts/Sarabun-Regular.ttf") format("truetype");font-weight:400;font-display:block}
      @font-face{font-family:"Sarabun";src:url("assets/fonts/Sarabun-SemiBold.ttf") format("truetype");font-weight:600;font-display:block}
      @font-face{font-family:"Sarabun";src:url("assets/fonts/Sarabun-Bold.ttf") format("truetype");font-weight:700;font-display:block}
      @font-face{font-family:"Sarabun";src:url("assets/fonts/Sarabun-ExtraBold.ttf") format("truetype");font-weight:800;font-display:block}
      @font-face{font-family:"Kanit";src:url("assets/fonts/Kanit-Bold.ttf") format("truetype");font-weight:700;font-display:block}
      @font-face{font-family:"Kanit";src:url("assets/fonts/Kanit-ExtraBold.ttf") format("truetype");font-weight:800;font-display:block}
      @font-face{font-family:"Kanit";src:url("assets/fonts/Kanit-Black.ttf") format("truetype");font-weight:900;font-display:block}
      @font-face{font-family:"Prompt";src:url("assets/fonts/Prompt-SemiBold.ttf") format("truetype");font-weight:600;font-display:block}
      @font-face{font-family:"Prompt";src:url("assets/fonts/Prompt-Bold.ttf") format("truetype");font-weight:700;font-display:block}
      @font-face{font-family:"Prompt";src:url("assets/fonts/Prompt-ExtraBold.ttf") format("truetype");font-weight:800;font-display:block}
      @font-face{font-family:"IBM Plex Sans Thai";src:url("assets/fonts/IBMPlexSansThai-Medium.ttf") format("truetype");font-weight:500;font-display:block}
      @font-face{font-family:"IBM Plex Sans Thai";src:url("assets/fonts/IBMPlexSansThai-SemiBold.ttf") format("truetype");font-weight:600;font-display:block}

      {{.BrandCSS}}
      /* Style-B body uses --amber* but BrandCSS emits --orange*; alias so the
         brand stays single-source. (--red/--green/--ease-* already in BrandCSS.) */
      :root{ --amber:var(--orange); --amber-soft:var(--orange-soft); --amber-bright:var(--orange-bright); }
      .kicker,h1.title,.stat,.stat-label,.step-of,.step-title,.pill,.cta,.brandbig,
      .chip .n,.badge-brand,.cap-word.key{font-family:var(--font-heading,"Sarabun"),sans-serif}
      /* per-theme texture (brand palette stays constant; texture adds feel) */
      [data-theme="neon-techno"] .scrim{background:
        linear-gradient(180deg, rgba(6,24,64,.10) 0%, rgba(6,24,64,.60) 45%, rgba(6,24,64,.95) 62%, var(--navy-deep) 100%)}
      [data-theme="neon-techno"] .scene-bg::after{content:"";position:absolute;inset:0;
        background-image:linear-gradient(rgba(46,139,255,.08) 1px,transparent 1px),
          linear-gradient(90deg,rgba(46,139,255,.08) 1px,transparent 1px);background-size:64px 64px}
      [data-theme="soft-3d-clay"] .card{border-radius:44px;
        box-shadow:0 30px 70px rgba(0,0,0,.35),inset 0 2px 0 rgba(255,255,255,.25)}
      *{margin:0;padding:0;box-sizing:border-box}
      html,body{width:{{.Width}}px;height:{{.Height}}px;overflow:hidden;background:var(--navy-deep)}
      /* Thai-safe: NEVER negative letter-spacing (it collides vowels/tone marks) */
      #root{position:relative;width:{{.Width}}px;height:{{.Height}}px;overflow:hidden;
        font-family:"Sarabun",sans-serif;letter-spacing:0;color:var(--ink);background:var(--navy-deep)}

      /* ── scene shell ── */
      .scene{position:absolute;inset:0;opacity:0;overflow:hidden}
      .scene-bg{position:absolute;inset:0;background-position:center top;background-size:cover;
        background-repeat:no-repeat;will-change:transform;transform-origin:center center}
      /* strong scrim: image reads at top, content sits on clean navy below */
      .scrim{position:absolute;inset:0;background:
        linear-gradient(180deg, rgba(6,24,64,.12) 0%, rgba(6,24,64,.55) 40%, rgba(6,24,64,.92) 60%, var(--navy-deep) 100%)}

      /* content lives in the lower ~55%, above the caption band */
      .scene-content{position:absolute;left:56px;right:56px;bottom:430px;
        display:flex;flex-direction:column;gap:26px;align-items:stretch}

      /* A2: per-layout composition so scenes don't all sit dead-center. Each rule
         only nudges position/width/alignment — content elements are unchanged, so
         `hyperframes inspect` still guards against overflow. hero keeps the default. */
      .scene[data-layout="hook"] .scene-content{bottom:560px}                 /* raise the opener high on frame */
      .scene[data-layout="step"] .scene-content,
      .scene[data-layout="tip"]  .scene-content{align-items:flex-start}       /* left-align step & tip flow */
      .scene[data-layout="tip"]  .pill{align-self:flex-start}                 /* pill follows the left edge */
      .scene[data-layout="cta"]  .scene-content{top:0;bottom:0;justify-content:center} /* dead-center the close */

      .kicker{font-weight:800;font-size:30px;line-height:1.3;letter-spacing:.10em;color:var(--amber-bright);text-align:center}

      /* Thai needs a loose line-height: at 1.06 the upper vowels/tone marks of a
         wrapped second line collide with the line above (ทับซ้อน). 1.32 + a little
         top room clears the stacked marks. */
      h1.title{font-weight:800;font-size:96px;line-height:1.32;padding-top:.06em;color:#fff;text-align:center;
        text-shadow:0 3px 16px rgba(0,0,0,.6)}
      h1.title .slab{color:#fff;background:var(--amber);padding:.02em .14em;border-radius:12px;
        box-decoration-break:clone;-webkit-box-decoration-break:clone}
      h1.title .acc{color:var(--amber-bright)}

      /* glass card */
      .card{background:linear-gradient(180deg,rgba(20,60,140,.5),rgba(10,35,88,.55));
        border:1.5px solid rgba(188,210,255,.26);border-radius:34px;padding:46px 44px;
        box-shadow:0 26px 70px rgba(0,0,0,.45),inset 0 1px 0 rgba(255,255,255,.16);backdrop-filter:blur(2px)}

      /* stat */
      .stat{font-weight:800;font-size:230px;line-height:.9;color:var(--amber-bright);text-align:center;
        white-space:nowrap;font-variant-numeric:tabular-nums;text-shadow:0 8px 44px rgba(255,180,84,.3)}
      .stat .unit{font-size:.37em;color:#fff;margin-left:10px}
      .stat-label{margin-top:14px;font-weight:700;font-size:42px;color:#fff;text-align:center;line-height:1.25}

      /* chips row */
      .chips{display:flex;gap:20px}
      .chip{flex:1;background:rgba(10,35,88,.66);border:1.5px solid rgba(188,210,255,.2);
        border-radius:22px;padding:26px 20px;text-align:center}
      .chip .n{font-weight:800;font-size:52px;white-space:nowrap;color:#fff}
      .chip .t{margin-top:6px;font-weight:600;font-size:26px;color:var(--muted);line-height:1.3}

      /* step header */
      .step-head{display:flex;align-items:center;gap:24px}
      .step-num{flex:0 0 auto;width:118px;height:118px;border-radius:28px;
        background:linear-gradient(135deg,var(--amber),var(--amber-soft));
        display:flex;align-items:center;justify-content:center;
        font-weight:800;font-size:72px;color:#fff;box-shadow:0 16px 40px rgba(255,180,84,.4)}
      .step-of{font-weight:700;font-size:30px;line-height:1.3;letter-spacing:.08em;color:var(--amber-bright)}
      .step-title{font-weight:800;font-size:60px;line-height:1.3;color:#fff}

      /* bullet rows (no emoji — amber dot) */
      .rows{display:flex;flex-direction:column;gap:16px}
      .row{display:flex;align-items:flex-start;gap:18px;
        background:rgba(10,35,88,.6);border:1px solid rgba(255,255,255,.08);
        border-radius:20px;padding:24px 28px}
      .row .dot{flex:0 0 auto;width:18px;height:18px;margin-top:14px;border-radius:50%;
        background:var(--amber-bright);box-shadow:0 0 14px rgba(255,180,84,.6)}
      .row .rt{font-weight:700;font-size:40px;line-height:1.26;color:#fff}
      .row.bad .dot{background:var(--red);box-shadow:0 0 14px rgba(255,107,98,.6)}
      .row.bad .rt{color:#ffd9d6}

      /* badge pill (TIP / category) */
      .pill{align-self:center;font-weight:800;font-size:30px;letter-spacing:.12em;
        color:var(--amber-bright);border:2px solid var(--amber-bright);background:rgba(255,180,84,.08);
        padding:14px 30px;border-radius:999px}

      .sub{font-weight:600;font-size:42px;line-height:1.3;color:var(--muted);text-align:center}

      /* cta */
      .cta{align-self:center;font-weight:800;font-size:46px;color:#fff;
        background:linear-gradient(135deg,var(--amber),var(--amber-soft));
        padding:26px 64px;border-radius:999px;box-shadow:0 20px 56px rgba(255,180,84,.4)}
      .brandbig{font-weight:800;font-size:88px;line-height:1.3;color:#fff;text-align:center;letter-spacing:.04em}

      /* ── progress / badges / caption ── */
      .progress-track{position:absolute;top:0;left:0;width:{{.Width}}px;height:10px;background:rgba(255,255,255,.08);z-index:30}
      .progress-fill{position:absolute;top:0;left:0;width:0;height:10px;
        background:linear-gradient(90deg,var(--amber-bright),var(--amber-soft));box-shadow:0 0 22px rgba(255,180,84,.6)}
      .badge-row{position:absolute;top:74px;left:56px;display:flex;align-items:center;gap:18px;z-index:25;opacity:0}
      .badge-brand{font-weight:800;font-size:34px;letter-spacing:.12em;color:#fff;background:var(--amber);
        padding:14px 28px;border-radius:14px;box-shadow:0 12px 30px rgba(255,180,84,.35)}
      .badge-cat{font-weight:700;font-size:26px;letter-spacing:.18em;color:var(--amber-bright);
        border:2px solid rgba(255,180,84,.5);padding:12px 22px;border-radius:14px;background:rgba(255,180,84,.08)}

      .cap-stage{position:absolute;left:0;right:0;bottom:210px;display:flex;justify-content:center;
        pointer-events:none;z-index:28}
      .cap-phrase{position:absolute;bottom:0;width:920px;text-align:center;
        font-weight:700;font-size:48px;line-height:1.34;color:#fff;
        background:rgba(8,24,64,.86);border:2px solid var(--amber-bright);border-radius:24px;
        padding:26px 40px;opacity:0;box-shadow:0 18px 50px rgba(0,0,0,.5)}
      /* Thai line breaking: no `anywhere` / `word-break:break-word` — Chromium's
         ICU dictionary breaks Thai at word boundaries by default; break-word is
         kept only as the last-resort escape for a truly unbreakable run. */
      .cap-word{display:inline;white-space:normal;overflow-wrap:break-word}
      h1.title,.stat-label,.row .rt,.step-title,.step-of,.kicker,.sub,.brandbig,
      .chip .t{overflow-wrap:break-word}
      .cta,.pill{max-width:100%;overflow-wrap:break-word}
      /* key word is inline-block so GSAP can scale it (transform is a no-op on inline) */
      .cap-word.key{color:var(--amber-bright);font-weight:800;display:inline-block;will-change:transform}
    </style>
  </head>
  <body>
    <div id="root" data-theme="{{.ThemeKey}}" data-composition-id="main" data-start="0" data-duration="{{.DurationSeconds}}" data-width="{{.Width}}" data-height="{{.Height}}">

      <div id="progress" class="clip progress-track" data-start="0" data-duration="{{.DurationSeconds}}" data-track-index="7">
        <div class="progress-fill" id="progressFill"></div></div>
      <div id="badges" class="clip badge-row" data-start="0.3" data-duration="{{.DurationSeconds}}" data-track-index="2">
        <div class="badge-brand">{{.BrandName}}</div><div class="badge-cat">{{.CategoryLabel}}</div></div>
      <div id="capStage" class="clip cap-stage" data-start="0" data-duration="{{.DurationSeconds}}" data-track-index="9" data-layout-allow-overflow></div>

      <audio id="vo" data-start="0" data-duration="{{.DurationSeconds}}" data-track-index="5" src="{{.VoiceSrc}}" data-volume="1"></audio>
      {{if .AmbientSrc}}<audio id="amb" data-start="0" data-duration="{{.DurationSeconds}}" data-track-index="3" src="{{.AmbientSrc}}" data-volume="0.15"></audio>{{end}}
      {{range $i, $cue := .TransitionCues}}<audio id="sfx{{$i}}" data-start="{{$cue.AtSec}}" data-duration="1.0" data-track-index="{{addInt 30 $i}}" src="{{$cue.Src}}" data-volume="0.5"></audio>
      {{end}}
    </div>

    <script>
      const tl = gsap.timeline({ paused: true });
      const TOTAL = {{.DurationSeconds}};
      const MOTION_UP = {{if .AudioMotion}}true{{else}}false{{end}};
      const MOTION_V2 = {{if .MotionV2}}true{{else}}false{{end}};
      const ENTRANCE_DUR = {{.EntranceDur}} || 0.6;
      const ENTRANCE_EASE = "{{.EntranceEase}}" || "power3.out";
      const BG_ZOOM_TO = {{.BGZoomTo}} || 1.06;

      // ── Scene content (cleaned: NO emoji, real slots) ──
      const SCENES = {{.ScenesJSON}};

      // Build the per-scene wrappers in-page from SCENES (start/end/bg), inserted
      // ahead of the #progress overlay so track order matches the static layout.
      const root = document.getElementById("root");
      SCENES.forEach((sc, i) => {
        const w = document.createElement("div");
        w.id = "scene-" + sc.scene; w.className = "scene clip";
        w.setAttribute("data-start", sc.start);
        w.setAttribute("data-duration", Math.max(0.1, sc.end - sc.start).toFixed(3));
        w.setAttribute("data-track-index", 10 + i);
        w.setAttribute("data-layout", sc.type || "");
        w.setAttribute("data-layout-allow-overflow", "");
        w.innerHTML =
          (sc.bg ? '<div class="scene-bg" style="background-image:url(\'' + sc.bg + '\')"></div>' : '<div class="scene-bg"></div>') +
          '<div class="scrim"></div><div class="scene-content" data-i="' + i + '"></div>';
        root.insertBefore(w, document.getElementById("progress"));
      });

      const SEGMENTS = {{.SegmentsJSON}};

      function el(tag,cls,html){const e=document.createElement(tag);if(cls)e.className=cls;if(html!=null)e.innerHTML=html;return e;}
      function rowsBlock(rows){const w=el("div","rows");(rows||[]).forEach(r=>{const row=el("div","row"+(r.bad?" bad":""));row.appendChild(el("div","dot"));row.appendChild(el("div","rt",r.t));w.appendChild(row);});return w;}
      function chipsBlock(chips){const w=el("div","chips");chips.forEach(c=>{const ch=el("div","chip");ch.appendChild(el("div","n",c.n));ch.appendChild(el("div","t",c.t.replace(/\n/g,"<br>")));w.appendChild(ch);});return w;}

      SCENES.forEach((sc,i)=>{
        const c=document.querySelector('.scene-content[data-i="'+i+'"]');
        if(!c)return;
        if(sc.kicker) c.appendChild(el("div","kicker",sc.kicker));
        if(sc.type==="hook"){ c.appendChild(rowsBlock(sc.rows)); }
        else if(sc.type==="hero"){ c.appendChild(el("h1","title",sc.title)); if(sc.sub)c.appendChild(el("div","sub",sc.sub)); }
        else if(sc.type==="stat"){
          const card=el("div","card");
          const meta=MOTION_V2?parseStatNumber(sc.stat):null;
          const numHTML=meta?'<span class="stat-num" data-final="'+sc.stat+'">0</span>':(sc.stat||"");
          card.appendChild(el("div","stat",numHTML+(sc.unit?'<span class="unit">'+sc.unit+'</span>':'')));
          card.appendChild(el("div","stat-label",sc.statLabel));
          c.appendChild(card);
          if(sc.chips) c.appendChild(chipsBlock(sc.chips));
        }
        else if(sc.type==="step"){
          const head=el("div","step-head");
          head.appendChild(el("div","step-num",sc.num));
          const tw=el("div");tw.appendChild(el("div","step-of",sc.of));tw.appendChild(el("div","step-title",sc.title));
          head.appendChild(tw); c.appendChild(head);
          c.appendChild(rowsBlock(sc.rows));
        }
        else if(sc.type==="tip"){ c.appendChild(el("div","pill",sc.pill)); c.appendChild(rowsBlock(sc.rows)); }
        else if(sc.type==="cta"){
          c.appendChild(el("h1","title",sc.title));
          c.appendChild(el("div","cta",sc.cta));
          c.appendChild(el("div","brandbig",sc.brand));
          if(sc.sub)c.appendChild(el("div","sub",sc.sub));
        }
      });

      // ── auto-fit: Kanit/Prompt Thai glyphs run wider than the Sarabun these px
      // sizes were tuned for. Both .stat and .chip .n are nowrap blocks that can
      // overflow their box; shrink font-size until they fit (floor 55%). Layout
      // is computed even while scenes sit at opacity:0, so measuring here is
      // safe. The MOTION_V2 stat counts up from "0", so measure at its widest
      // (final) value first. Runs after document.fonts.ready (when available) so
      // scrollWidth reflects real Kanit/Prompt metrics, not the fallback font.
      function fitText(node){
        let size=parseFloat(getComputedStyle(node).fontSize);
        const min=size*0.55;
        let guard=60;
        while(guard-->0&&size>min&&node.scrollWidth>node.clientWidth+1){
          size=Math.max(min,size-2);
          node.style.fontSize=size+"px";
        }
      }
      function autoFit(){
        document.querySelectorAll(".scene-content .stat,.scene-content .chip .n").forEach(function(node){
          node.style.fontSize=""; // re-entry safe: always measure from the CSS size
          const num=node.querySelector(".stat-num");
          if(num)num.textContent=num.getAttribute("data-final")||"0";
          fitText(node);
          if(num)num.textContent="0";
        });
      }
      if(document.fonts&&document.fonts.ready){document.fonts.ready.then(autoFit);}else{autoFit();}

      // ── continuous overlays ──
      tl.fromTo("#progressFill",{width:0},{width:{{.Width}},duration:TOTAL,ease:"none"},0);
      tl.fromTo("#badges",{opacity:0,x:-40},{opacity:1,x:0,duration:.6,ease:"power3.out"},0.3);
      tl.to("#badges",{opacity:0,y:-20,duration:.5,ease:"power2.in"},Math.min(7,TOTAL*0.18));

      // A1 entrance pacing factors (multiply base entrance durations):
      // fast = snappy hook, slow = premium hero/stat reveal, absent = normal (1.0).
      const SPEED_FACTORS={fast:0.7,slow:1.35};
      // contentEntrance returns the from/to vars for a scene's content entrance.
      // MOTION_V2 off → the legacy rise (y-based). MOTION_V2 on → per-scene
      // geometry from sc.entrance (punch/rise/slide); slide alternates direction.
      function contentEntrance(sc, motionUp){
        const base = motionUp ? 60 : 46;
        const rise = {from:{y:base,opacity:0}, to:{y:0,opacity:1}};
        if(!MOTION_V2) return rise;
        const v = sc.entrance || "rise";
        if(v==="slide"){ const dx = (sc.scene % 2 === 0) ? -80 : 80; return {from:{x:dx,opacity:0}, to:{x:0,opacity:1}}; }
        if(v==="punch"){ return {from:{scale:0.9,opacity:0}, to:{scale:1,opacity:1}}; }
        return rise;
      }
      // parseStatNumber extracts the leading number of a stat string ("80",
      // "1,200", "3.5") → {value, decimals, grouped}, or null if non-numeric.
      function parseStatNumber(s){
        const m = String(s||"").match(/^\s*([\d.,]+)\s*$/);
        if(!m) return null;
        const raw = m[1];
        const grouped = raw.indexOf(",") >= 0;
        const clean = raw.replace(/,/g,"");
        const value = parseFloat(clean);
        if(!isFinite(value)) return null;
        const dot = clean.indexOf(".");
        const decimals = dot >= 0 ? clean.length - dot - 1 : 0;
        return {value:value, decimals:decimals, grouped:grouped};
      }
      function formatStat(v, meta){
        let s = meta.decimals > 0 ? v.toFixed(meta.decimals) : String(Math.round(v));
        if(meta.grouped){ const parts = s.split("."); parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ","); s = parts.join("."); }
        return s;
      }
      // ── per-scene: ONE entrance per element, no conflicting tweens ──
      SCENES.forEach((sc,idx)=>{
        const sceneEl=document.getElementById("scene-"+sc.scene);
        if(!sceneEl)return;
        const inAt=idx===0?0:Math.max(0,sc.start-0.35);
        const content=sceneEl.querySelector(".scene-content");
        const bg=sceneEl.querySelector(".scene-bg");
        const span=Math.max(0.4,sc.end-inAt);

        const SPEED_FACTOR=SPEED_FACTORS[sc.speed]||1.0;
        // entranceEnd = when the content entrance finishes; the MOTION_V2 drift
        // reuses it so its start stays in sync with whichever entrance branch ran.
        let entranceEnd = sc.start + 0.7;

        if (MOTION_UP) {
          // Upgraded: incoming scene slides up + scales in while fading; bg ken-burns.
          const durIn=ENTRANCE_DUR*SPEED_FACTOR;
          entranceEnd = sc.start + 0.08 + durIn;
          tl.fromTo(sceneEl,{opacity:0,scale:1.04},{opacity:1,scale:1,duration:idx===0?0.5:durIn,ease:ENTRANCE_EASE},inAt);
          if(bg) tl.fromTo(bg,{scale:1.04},{scale:BG_ZOOM_TO,duration:span,ease:"none"},inAt);
          if(content){
            const ce=contentEntrance(sc,true);
            tl.fromTo(content,ce.from,Object.assign({},ce.to,{duration:durIn,ease:ENTRANCE_EASE}),sc.start+0.08);
          }
        } else {
          // Current behavior, now speed-scaled per scene.
          const contentDurIn=0.6*SPEED_FACTOR;
          entranceEnd = sc.start + 0.1 + contentDurIn;
          tl.fromTo(sceneEl,{opacity:0},{opacity:1,duration:idx===0?0.5:0.55*SPEED_FACTOR,ease:"power2.out"},inAt);
          if(bg) tl.fromTo(bg,{scale:1.0},{scale:1.06,duration:span,ease:"none"},inAt);
          if(content){
            const ce=contentEntrance(sc,false);
            tl.fromTo(content,ce.from,Object.assign({},ce.to,{duration:contentDurIn,ease:"power3.out"}),sc.start+0.1);
          }
        }

        if(content){
          const kids=content.children;
          for(let j=0;j<kids.length;j++){
            const isStat=kids[j].querySelector&&kids[j].querySelector(".stat");
            if(isStat){
              tl.fromTo(kids[j],{scale:0.78,opacity:0},{scale:1,opacity:1,duration:0.5,ease:"back.out(1.7)"},sc.start+0.28+j*0.08);
            }else{
              tl.fromTo(kids[j],{opacity:0,y:18},{opacity:1,y:0,duration:0.42,ease:"power3.out"},sc.start+0.26+j*0.09);
            }
          }
        }

        // MOTION_V2: after the entrance settles, drift the whole content block
        // slowly upward (opposite the bg ken-burns) so the focal content is never
        // dead-still. Starts after the entrance so it never fights the entrance's
        // own y/scale tween.
        if(MOTION_V2 && content){
          // Start the drift 0.1s AFTER the content entrance finishes so it never
          // fights the entrance's own y tween (the "rise" variant animates y too).
          const driftStart = entranceEnd + 0.1;
          const driftDur = sc.end - driftStart;
          if(driftDur > 0.3){
            tl.to(content,{y:-12,duration:driftDur,ease:"none"},driftStart);
          }
        }
        if(MOTION_V2 && sc.type==="stat"){
          const numEl = sceneEl.querySelector(".stat-num");
          const meta = parseStatNumber(sc.stat);
          if(numEl && meta){
            const proxy = {v:0};
            tl.to(proxy,{v:meta.value,duration:Math.min(1.1,Math.max(0.5,span*0.5)),ease:"power1.out",
              onUpdate:function(){ numEl.textContent = formatStat(proxy.v, meta); }},sc.start+0.3);
          }
        }
        tl.set(sceneEl,{opacity:0},sc.end);
      });

      // ── captions (phrase fade + key-word amber) ──
      const seg2=typeof Intl!=="undefined"&&Intl.Segmenter?new Intl.Segmenter(undefined,{granularity:"grapheme"}):null;
      function gl(t){if(seg2){let o=[];for(const s of seg2.segment(t))o.push(s.segment);return o;}return Array.from(t);}
      function splitWords(t){const o=[];const re=/\S+\s*/g;let m;while((m=re.exec(t))!==null)o.push(m[0]);if(!o.length&&t.length)o.push(t);return o;}
      function keyIdx(ws,emph){
        // Prefer a word that matches the scene's emphasis; fall back to longest.
        if(emph&&emph.length){
          for(let i=0;i<ws.length;i++){const t=ws[i].trim();
            for(const e of emph){if(e&&t.indexOf(e)>=0)return i;}}
        }
        let b=0,bl=-1;ws.forEach((w,i)=>{const l=gl(w.trim()).length;if(l>bl){bl=l;b=i;}});return b;
      }
      // A4 key-word glow color, read from the active palette so it tracks the brand
      // instead of a hardcoded hex (falls back to brand orange if the var is missing).
      const accentHex=getComputedStyle(document.documentElement).getPropertyValue("--amber-bright").trim();
      const KEY_ACCENT=/^#[0-9a-fA-F]{6}$/.test(accentHex)?accentHex:"#F0A030";
      const capStage=document.getElementById("capStage");
      SEGMENTS.forEach((seg,i)=>{
        const p=el("div","cap-phrase");
        const ws=splitWords(seg.text);const k=keyIdx(ws,seg.emph);
        let keyEl=null;
        ws.forEach((w,wi)=>{const s=el("span","cap-word"+(wi===k?" key":""));s.textContent=w;p.appendChild(s);if(wi===k)keyEl=s;});
        capStage.appendChild(p);
        const inAt=seg.start;
        const outAt=i<SEGMENTS.length-1?SEGMENTS[i+1].start:seg.end;
        tl.fromTo(p,{opacity:0,y:16},{opacity:1,y:0,duration:0.28,ease:"power3.out"},inAt);
        // A4: the emphasis word pops in with a scale + palette glow, then settles to a
        // soft resting glow so it stays legible. GSAP-only (seek-safe) — no CSS keyframes.
        // 8-digit hex alpha (E6≈.9, 66≈.4, 00=0) keeps the color palette-driven.
        if(keyEl){
          tl.fromTo(keyEl,{scale:1,textShadow:"0 0 0px "+KEY_ACCENT+"00"},
            {scale:1.14,textShadow:"0 0 20px "+KEY_ACCENT+"E6",duration:0.24,ease:"back.out(2)"},inAt+0.10);
          tl.to(keyEl,{scale:1,textShadow:"0 0 8px "+KEY_ACCENT+"66",duration:0.30,ease:"power2.out"},inAt+0.38);
        }
        tl.to(p,{opacity:0,y:-12,duration:0.22,ease:"power2.in"},Math.max(inAt+0.4,outAt-0.2));
        tl.set(p,{opacity:0},outAt);
      });

      tl.set({},{},TOTAL);
      window.__timelines=window.__timelines||{};
      window.__timelines["main"]=tl;
    </script>
  </body>
</html>{{end}}
